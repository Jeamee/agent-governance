{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance module boundaries",
  "type": "object",
  "required": ["modules"],
  "properties": {
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["module_id", "prefix"],
        "properties": {
          "module_id": {"type": "string", "pattern": "^MODULE-[A-Z0-9-]+$"},
          "prefix": {"type": "string", "pattern": "^([^/]+/|\\.[^/]+/)$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
