{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance requirements manifest",
  "type": "object",
  "required": ["task_id", "requirements"],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "required_verifiers"],
        "properties": {
          "id": {"type": "string", "pattern": "^(ACC|ARC|OPS|UIQ)-[A-Z0-9]+-[0-9]{3}$"},
          "kind": {"enum": ["behavior", "architecture", "operability", "ui_quality"]},
          "preconditions": {"type": "string"},
          "action": {"type": "string"},
          "expected": {"type": "string"},
          "forbidden": {"type": "string"},
          "requirement": {"type": "string"},
          "required_verifiers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {"enum": ["test", "contract_test", "real_db_test", "browser_test", "umbrella_e2e", "mutation", "evidence", "human_approval", "static_rule", "regression_red", "before_after"]},
                "id": {"type": "string", "minLength": 1},
                "rubric": {"type": "string", "minLength": 1}
              },
              "anyOf": [{"required": ["id"]}, {"required": ["rubric"]}],
              "additionalProperties": false
            }
          }
        },
        "allOf": [
          {"if": {"properties": {"kind": {"const": "behavior"}}}, "then": {"required": ["preconditions", "action", "expected", "forbidden"]}},
          {"if": {"properties": {"kind": {"enum": ["architecture", "operability"]}}}, "then": {"required": ["requirement"]}}
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
