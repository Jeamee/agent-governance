{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance authorization record",
  "type": "object",
  "required": ["task_id", "design_ref", "gate_ref", "allowed_repositories", "implementation_plan_digest", "required_profiles", "lead_repository"],
  "properties": {
    "task_id": {"type": "string"},
    "design_ref": {"$ref": "#/$defs/ref"},
    "gate_ref": {"$ref": "#/$defs/gateRef"},
    "allowed_repositories": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "implementation_plan_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "required_profiles": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "lead_repository": {"type": "string"}
  },
  "$defs": {
    "ref": {"type": "object", "required": ["repository", "commit", "path", "digest"], "properties": {"repository": {"type": "string"}, "commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"}, "path": {"type": "string"}, "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}, "additionalProperties": false},
    "gateRef": {"type": "object", "required": ["repository", "commit"], "properties": {"repository": {"type": "string"}, "commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
