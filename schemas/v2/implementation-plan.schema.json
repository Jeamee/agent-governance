{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance implementation plan v2",
  "type": "object",
  "required": ["schema_version", "task_id", "steps"],
  "properties": {
    "schema_version": {"const": 2},
    "task_id": {"type": "string", "minLength": 1},
    "steps": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["step_id", "kind", "depends_on"], "properties": {"step_id": {"type": "string", "pattern": "^STEP-[0-9]{3}$"}, "kind": {"enum": ["change", "verify"]}, "depends_on": {"type": "array", "items": {"type": "string", "pattern": "^STEP-[0-9]{3}$"}}, "targets": {"type": "array", "minItems": 1, "items": {"type": "object", "properties": {"path": {"type": "string", "minLength": 1}, "module_id": {"type": "string", "pattern": "^MODULE-[A-Z0-9-]+$"}, "prefix": {"type": "string", "minLength": 1}, "scope_reason": {"type": "string", "minLength": 1}}, "oneOf": [{"required": ["path"]}, {"required": ["module_id", "prefix", "scope_reason"]}], "additionalProperties": false}}, "requirement_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "verifier_ids": {"type": "array", "items": {"type": "string", "minLength": 1}}, "completion": {"type": "object", "properties": {"command_ids": {"type": "array", "items": {"type": "string"}}, "evidence_scene_ids": {"type": "array", "items": {"type": "string"}}, "approval_rubric_ids": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false}, "note": {"type": "string"}}, "allOf": [{"if": {"properties": {"kind": {"const": "change"}}, "required": ["kind"]}, "then": {"required": ["targets", "requirement_ids"]}}, {"if": {"properties": {"kind": {"const": "verify"}}, "required": ["kind"]}, "then": {"required": ["verifier_ids", "completion"]}}], "additionalProperties": false}}
  },
  "additionalProperties": false
}
