{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance evidence scenes v2",
  "type": "object",
  "required": ["schema_version", "scenes"],
  "properties": {"schema_version": {"const": 2}, "scenes": {"type": "array", "items": {"type": "object", "required": ["id", "for", "must_show"], "properties": {"id": {"type": "string", "pattern": "^SCENE-[A-Z0-9-]+$"}, "for": {"oneOf": [{"type": "string"}, {"type": "array", "minItems": 1, "items": {"type": "string"}}]}, "must_show": {"type": "string", "minLength": 1}}, "additionalProperties": false}}},
  "additionalProperties": false
}
