{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance delivery request v2",
  "type": "object",
  "required": ["schema_version", "task_id", "design_ref", "gate_ref", "task_type", "implementation_commits", "out_of_manifest_branch", "dev_records", "remaining_risks"],
  "properties": {
    "schema_version": {"const": 2},
    "task_id": {"type": "string", "minLength": 1},
    "design_ref": {"$ref": "#/$defs/designRef"},
    "gate_ref": {"$ref": "#/$defs/gateRef"},
    "task_type": {"enum": ["bugfix", "feature", "refactor"]},
    "implementation_commits": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/sha"}},
    "out_of_manifest_branch": {"type": "object", "required": ["declared", "description"], "properties": {"declared": {"type": "boolean"}, "description": {"type": "string"}}, "additionalProperties": false},
    "dev_records": {"type": "array", "items": {"$ref": "#/$defs/dev"}},
    "remaining_risks": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "designRef": {"type": "object", "required": ["repository", "commit", "path", "digest"], "properties": {"repository": {"type": "string"}, "commit": {"$ref": "#/$defs/sha"}, "path": {"type": "string", "pattern": "^docs/designs/.+/$"}, "digest": {"$ref": "#/$defs/digest"}}, "additionalProperties": false},
    "gateRef": {"type": "object", "required": ["repository", "commit"], "properties": {"repository": {"type": "string"}, "commit": {"$ref": "#/$defs/sha"}}, "additionalProperties": false},
    "dev": {"type": "object", "required": ["id", "plan_step_ids", "category", "actual_files", "affected_requirements", "reason", "verification_impact"], "properties": {"id": {"type": "string", "pattern": "^DEV-[0-9]{3}$"}, "plan_step_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^STEP-[0-9]{3}$"}}, "category": {"enum": ["file_split", "reorder", "approach_change", "extra_file"]}, "actual_files": {"type": "array", "items": {"type": "string", "minLength": 1}}, "affected_requirements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "reason": {"type": "string", "minLength": 1}, "verification_impact": {"enum": ["none", "tests_updated", "needs_review"]}}, "allOf": [{"if": {"properties": {"category": {"enum": ["file_split", "extra_file", "approach_change"]}}, "required": ["category"]}, "then": {"properties": {"actual_files": {"minItems": 1}}}}], "additionalProperties": false}
  },
  "additionalProperties": false
}
