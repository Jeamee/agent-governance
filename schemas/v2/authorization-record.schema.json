{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance authorization record v2",
  "type": "object",
  "required": ["schema_version", "task_id", "design_ref", "gate_ref", "allowed_repositories", "implementation_plan_digest", "required_profiles", "lead_repository", "coverage_base_commit"],
  "properties": {
    "schema_version": {"const": 2},
    "task_id": {"type": "string", "minLength": 1},
    "design_ref": {"$ref": "#/$defs/designRef"},
    "gate_ref": {"$ref": "#/$defs/gateRef"},
    "allowed_repositories": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "implementation_plan_digest": {"$ref": "#/$defs/digest"},
    "required_profiles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "lead_repository": {"type": "string", "minLength": 1},
    "coverage_base_commit": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "designRef": {"type": "object", "required": ["repository", "commit", "path", "digest"], "properties": {"repository": {"type": "string", "minLength": 1}, "commit": {"$ref": "#/$defs/sha"}, "path": {"type": "string", "pattern": "^docs/designs/.+/$"}, "digest": {"$ref": "#/$defs/digest"}}, "additionalProperties": false},
    "gateRef": {"type": "object", "required": ["repository", "commit"], "properties": {"repository": {"type": "string", "minLength": 1}, "commit": {"$ref": "#/$defs/sha"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
