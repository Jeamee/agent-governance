{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance module boundaries v2",
  "type": "object",
  "required": ["schema_version", "modules"],
  "properties": {
    "schema_version": {"const": 2},
    "modules": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["module_id", "prefix"], "properties": {"module_id": {"type": "string", "pattern": "^MODULE-[A-Z0-9-]+$"}, "prefix": {"type": "string", "pattern": "^(?:\\.?[A-Za-z0-9_-]+/)+(?:[A-Za-z0-9_-]+/)?$"}}, "additionalProperties": false}}
  },
  "additionalProperties": false
}
