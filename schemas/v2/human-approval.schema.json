{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance human approval v2",
  "type": "object",
  "required": ["schema_version", "rubric_id", "object_digest", "approved_by", "approved_at"],
  "properties": {"schema_version": {"const": 2}, "rubric_id": {"type": "string", "minLength": 1}, "object_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "approved_by": {"type": "string", "minLength": 1}, "approved_at": {"type": "string", "format": "date-time"}},
  "additionalProperties": false
}
