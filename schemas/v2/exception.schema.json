{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance exception record v2",
  "type": "object",
  "required": ["schema_version", "repository", "base_sha", "head_sha", "diff_digest", "policy_rule", "paths", "reason", "expires_at", "approval", "revoked"],
  "properties": {"schema_version": {"const": 2}, "repository": {"type": "string", "minLength": 1}, "base_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"}, "head_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"}, "diff_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "policy_rule": {"type": "string", "minLength": 1}, "paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "reason": {"type": "string", "minLength": 1}, "expires_at": {"type": "string", "format": "date-time"}, "approval": {"type": "object", "minProperties": 1}, "revoked": {"type": "boolean"}},
  "additionalProperties": false
}
